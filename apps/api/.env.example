# ── Database / infra ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/pouetpouet"
# Connexions Prisma par instance (defaut 10). Garder nb_instances x limite < max_connections Postgres.
# DB_CONNECTION_LIMIT=10
REDIS_HOST=localhost
REDIS_PORT=6379
JWT_SECRET=change-me
FRONTEND_URL=http://localhost:3000
PORT=4000

# ── Email verification ──────────────────────────────────────────────────────────
# When ALLOW_EMAIL_BYPASS=true, the registration form exposes a "create without
# verification" button and the dev verification link is returned to the client.
# Set to false (or remove) in production.
ALLOW_EMAIL_BYPASS=true

# SMTP for verification emails. When SMTP_HOST is empty, emails are logged to the
# server console instead of being sent (dev fallback).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM="PouetPouet <no-reply@pouetpouet.app>"

# ── Feature flags ─────────────────────────────────────────────────────────────
# Liste d'emails (séparés par des virgules) autorisés à administrer les feature
# flags (page /admin/flags + API /api/admin/flags). Laisser vide = aucun admin.
ADMIN_EMAILS=

# ── Monitoring ──────────────────────────────────────────────────────────────────
# Sentry error tracking. Leave empty to disable (dev default).
SENTRY_DSN=

# ── MeetOps : connecteur Microsoft Graph (Outlook + Teams) ───────────────────────
# Laisser vide pour désactiver l'envoi Graph (MeetOps reste utilisable, .ics en fallback).
# App enregistrée dans Azure AD (Entra ID) — permissions déléguées :
# Calendars.ReadWrite, OnlineMeetings.ReadWrite, offline_access, User.Read.
MS_GRAPH_CLIENT_ID=
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_SECRET=
# Doit correspondre EXACTEMENT au redirect URI déclaré dans Azure.
# MS_GRAPH_REDIRECT_URI=http://localhost:4000/api/meetops/graph/callback
# Clé de chiffrement des tokens stockés (défaut : JWT_SECRET si absent).
MS_GRAPH_TOKEN_KEY=

# ── Assistant Pouet (optionnel) ──────────────────────────────────────────────────
# LLM auto-hébergé via Ollama. Lancer : docker compose --profile ollama up -d ollama
# puis : docker compose --profile ollama exec ollama ollama pull llama3.2:3b
# En prod : pointer vers la VM/VPS Ollama dédiée.
OLLAMA_BASE_URL=http://localhost:11434
POUET_MODEL=llama3.2:3b

# ── SSO OIDC (optionnel) ─────────────────────────────────────────────────────────
# Identité fédérée : laisser vide pour désactiver (login local uniquement).
# IdP local de test : docker compose --profile sso up -d keycloak
# (realm "forge" importé depuis keycloak/, utilisateur sso-user / sso-password)
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_PROVIDER_NAME=SSO
# OIDC_REDIRECT_URI=https://api.example.com/api/auth/oidc/callback (défaut : http://localhost:4000/api/auth/oidc/callback)
