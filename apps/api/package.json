{
  "name": "@pouetpouet/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "start:prod": "npx prisma migrate deploy && node dist/index.js",
    "lint": "tsc --noEmit",
    "db:generate": "prisma generate",
