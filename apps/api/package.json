{
  "name": "@pouetpouet/api",
  "version": "0.15.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "start:prod": "npx prisma migrate deploy && node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=lcov --coverage.reporter=text",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@pouetpouet/shared": "*",
    "@prisma/client": "6.19.0",
    "@sentry/node": "^10.57.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/nodemailer": "^8.0.0",
    "bcryptjs": "^3.0.2",
    "fastify": "^5.3.2",
    "ioredis": "^5.6.1",
    "nodemailer": "^8.0.10",
    "openid-client": "^6.8.4",
    "socket.io": "^4.8.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.17",
    "prisma": "6.19.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  }
}
