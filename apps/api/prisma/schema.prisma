generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String
  password           String
  avatar             String?
  bio                String?
  theme              String    @default("light")
  palette            String    @default("default")
  emailVerified      Boolean   @default(false)
  verifyToken        String?   @unique
  verifyTokenExpires DateTime?
  resetToken         String?   @unique
  resetTokenExpires  DateTime?
  patchNotesSeenAt   DateTime?
  favoriteModules    String[]  @default([])
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  boards         Board[]
  boardShares    BoardShare[]
  notifications  Notification[]
  boardVotes     BoardVote[]
  boardFavorites BoardFavorite[]
  boardTemplates BoardTemplate[]
  sessions       SessionParticipant[]
  scrumRooms     ScrumRoom[]
  teams          Team[]
  dailySessions  DailySession[]
  wheelEvents    WheelEvent[]
  wheelDraws     WheelDraw[]
  capacityEvents   CapacityEvent[]
  meetEvents       MeetEvent[]
  meetDistLists    MeetDistList[]
  meetTemplates    MeetTemplate[]
  meetGraphAccount MeetGraphAccount?
  apiKeys          ApiKey[]
  webhooks       Webhook[]
  auditLogs      AuditLog[]
  oauthAccounts  OAuthAccount[]
  moduleShares   ModuleShare[]
  testBooks      TestBook[]
  quizzes        Quiz[]
  quizSessions   QuizSession[]
  gameScores     GameScore[]
}

// Lien compte local ↔ identité fédérée (OIDC). Un même utilisateur peut avoir
// plusieurs providers ; un (provider, sujet) ne mappe qu'un seul compte.
model OAuthAccount {
  id         String   @id @default(cuid())
  userId     String
  provider   String // issuer URL ou alias (ex. "keycloak", "google")
  subject    String // claim "sub" du token OIDC
  email      String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, subject])
  @@index([userId])
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  keyHash    String    @unique
  prefix     String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Webhook {
  id        String   @id @default(cuid())
  userId    String
  name      String
  url       String
  secret    String
  events    String[]
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([userId])
}

model WebhookDelivery {
  id         String   @id @default(cuid())
  webhookId  String
  event      String
  statusCode Int?
  error      String?
  durationMs Int
  createdAt  DateTime @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, createdAt])
}

model Board {
  id                String    @id @default(cuid())
  name              String
  description       String?
  coverImage        String?
  maxParticipants   Int?
  enabledActivities Json?
  ownerId           String
  shareToken        String?   @unique
  shareLinkRole     BoardRole @default(VIEWER)
  templateDraftOf   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  owner        User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  cards        Card[]
  connections  CardConnection[]
  frames       Frame[]
  fields       BoardField[]
  sessions     Session[]
  shares       BoardShare[]
  voteSessions BoardVoteSession[]
  favorites    BoardFavorite[]
}

model BoardFavorite {
  id        String   @id @default(cuid())
  userId    String
  boardId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@unique([userId, boardId])
}

model BoardTemplate {
  id                String   @id @default(cuid())
  name              String
  description       String?
  coverImage        String?
  maxParticipants   Int?
  enabledActivities Json?
  isFavorite        Boolean  @default(false)
  ownerId           String
  cards             Json
  frames            Json
  connections       Json
  fields            Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model BoardShare {
  id        String    @id @default(cuid())
  boardId   String
  userId    String
  role      BoardRole @default(VIEWER)
  createdAt DateTime  @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
}

model Card {
  id        String   @id @default(cuid())
  boardId   String
  type      CardType @default(TEXT)
  content   String
  meta      Json?
  posX      Float    @default(0)
  posY      Float    @default(0)
  width     Float    @default(192)
  height    Float    @default(128)
  color      String   @default("#FFEB3B")
  groupId    String?
  groupColor String?
  locked     Boolean  @default(false)
  layer      Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board           Board            @relation(fields: [boardId], references: [id], onDelete: Cascade)
  connectionsFrom CardConnection[] @relation("ConnectionFrom")
  connectionsTo   CardConnection[] @relation("ConnectionTo")
  fieldValues     CardFieldValue[]
}

model Frame {
  id        String   @id @default(cuid())
  boardId   String
  title     String   @default("Cadre")
  posX      Float    @default(0)
  posY      Float    @default(0)
  width     Float    @default(400)
  height    Float    @default(300)
  color     String   @default("#E0E7FF")
  active    Boolean  @default(false)
  layer     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
}

model BoardField {
  id        String    @id @default(cuid())
  boardId   String
  name      String
  emoji     String?
  type      FieldType @default(TEXT)
  options   Json?
  order     Int       @default(0)
  createdAt DateTime  @default(now())

  board  Board           @relation(fields: [boardId], references: [id], onDelete: Cascade)
  values CardFieldValue[]
}

model CardFieldValue {
  id      String @id @default(cuid())
  cardId  String
  fieldId String
  value   String

  card  Card       @relation(fields: [cardId], references: [id], onDelete: Cascade)
  field BoardField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([cardId, fieldId])
}

model CardConnection {
  id        String   @id @default(cuid())
  boardId   String
  fromId    String
  toId      String
  label     String?
  color     String?
  shape     String   @default("curved")
  arrow     String   @default("none")
  dashed    Boolean  @default(false)
  width     Float    @default(2)
  createdAt DateTime @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  from  Card  @relation("ConnectionFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to    Card  @relation("ConnectionTo", fields: [toId], references: [id], onDelete: Cascade)
}

model Session {
  id        String        @id @default(cuid())
  boardId   String
  code      String        @unique
  status    SessionStatus @default(WAITING)
  createdAt DateTime      @default(now())
  closedAt  DateTime?

  board        Board                @relation(fields: [boardId], references: [id], onDelete: Cascade)
  participants SessionParticipant[]
  activities   Activity[]
}

model SessionParticipant {
  id        String   @id @default(cuid())
  sessionId String
  userId    String?
  guestName String?
  joinedAt  DateTime @default(now())

  session   Session            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  responses ActivityResponse[]
}

model Activity {
  id        String         @id @default(cuid())
  sessionId String
  type      ActivityType
  title     String
  config    Json
  status    ActivityStatus @default(PENDING)
  createdAt DateTime       @default(now())

  session   Session            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  responses ActivityResponse[]
}

model ActivityResponse {
  id            String   @id @default(cuid())
  activityId    String
  participantId String
  value         Json
  createdAt     DateTime @default(now())

  activity    Activity           @relation(fields: [activityId], references: [id], onDelete: Cascade)
  participant SessionParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
}

// Per-user account activity feed (board shared, role changed, access revoked, board deleted).
// Patch notes are NOT stored here — they live in code and are tracked via User.patchNotesSeenAt.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// Journal des actions sensibles du compte (sécurité / conformité).
// Cascade à la suppression du compte : pas de PII orpheline (RGPD).
model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  resource  String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// Feature flags — surcharges runtime par environnement. Le catalogue des clés
// connues + leurs défauts vivent dans le code (packages/shared FLAG_DEFINITIONS) ;
// une ligne ici ne stocke que l'état modifié par un admin.
model FeatureFlag {
  id             String   @id @default(cuid())
  key            String
  environment    String // development | production | test
  enabled        Boolean  @default(false)
  rolloutPercent Int      @default(100) // 0-100, appliqué uniquement si enabled
  whitelist      String[] @default([]) // userIds toujours actifs (override du rollout)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([key, environment])
}

// Partage générique des ressources de module (Scrum, Daily, …). Polymorphe :
// (module, resourceId) référence la ressource sans FK — la cascade à la suppression
// de la ressource est gérée dans le code (deleteResourceShares). La cascade à la
// suppression de l'utilisateur passe par la relation user.
model ModuleShare {
  id         String     @id @default(cuid())
  module     String // 'scrum' | 'daily' | ...
  resourceId String
  userId     String
  role       ModuleRole @default(VIEWER)
  createdAt  DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([module, resourceId, userId])
  @@index([userId])
  @@index([module, resourceId])
}

enum ModuleRole {
  VIEWER
  EDITOR
  OWNER
}

enum BoardRole {
  VIEWER
  EDITOR
  OWNER // co-propriétaire via partage ; Board.ownerId reste le créateur (non rétrogradable)
}

enum CardType {
  TEXT
  IMAGE
  LINK
  SHAPE
  DRAW
  LABEL
  TABLE
}

enum FieldType {
  TEXT
  NUMBER
  DATE
  SELECT
}

enum SessionStatus {
  WAITING
  ACTIVE
  CLOSED
}

enum ActivityType {
  QUIZ
  POLL
  WORDCLOUD
  BRAINSTORM
  QA
}

enum ActivityStatus {
  PENDING
  ACTIVE
  CLOSED
}

// ── Scrum Poker ───────────────────────────────────────────────────────────────

model ScrumRoom {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  ownerId   String
  teamId    String?
  scale     String   @default("FIBONACCI")
  queue     String[] @default([]) // file ordonnée de ticketIds restant à estimer (tête = ticket courant)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner   User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  team    Team?         @relation(fields: [teamId], references: [id], onDelete: SetNull)
  tickets ScrumTicket[]
}

model ScrumTicket {
  id           String            @id @default(cuid())
  roomId       String
  title        String
  estimate     String?
  estimateTime String?
  order        Int
  status       ScrumTicketStatus @default(PENDING)
  createdAt    DateTime          @default(now())

  room  ScrumRoom   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  votes ScrumVote[]
}

model ScrumVote {
  id              String      @id @default(cuid())
  ticketId        String
  participantName String
  value           String
  scale           String      @default("FIBONACCI")
  createdAt       DateTime    @default(now())

  ticket ScrumTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@unique([ticketId, participantName, scale])
}

enum ScrumTicketStatus {
  PENDING
  VOTING
  REVEALED
  DONE
}

// ── Team pivot (socle FORGE F3) ───────────────────────────────────────────────
// Remplace DailyTeam et CapacityTeam. Une équipe est un pivot partagé par Daily,
// La Roue et Capacité. Les membres ont role/fte optionnels (Daily ne les utilise pas).

model Team {
  id          String   @id @default(cuid())
  name        String
  ownerId     String
  color       String   @default("#6366f1")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner          User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members        TeamMember[]
  wheelDraws     WheelDraw[]
  dailySessions  DailySession[]
  capacityEvents CapacityEvent[]
  scrumRooms     ScrumRoom[]
}

model TeamMember {
  id     String  @id @default(cuid())
  teamId String
  name   String
  role   String?
  fte    Float?
  order  Int     @default(0)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

// ── Daily Standup ─────────────────────────────────────────────────────────────

model DailySession {
  id            String      @id @default(cuid())
  name          String
  ownerId       String
  teamId        String?
  timePerPerson Int         @default(120)
  status        DailyStatus @default(PENDING)
  currentIndex  Int         @default(-1)
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  owner        User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  team         Team?              @relation(fields: [teamId], references: [id], onDelete: SetNull)
  participants DailyParticipant[]
}

model DailyParticipant {
  id           String                 @id @default(cuid())
  sessionId    String
  name         String
  order        Int
  speakingAt   DateTime?
  doneSpeaking DateTime?
  status       DailyParticipantStatus @default(WAITING)

  session DailySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

enum DailyStatus {
  PENDING
  RUNNING
  DONE
}

enum DailyParticipantStatus {
  WAITING
  SPEAKING
  DONE
  SKIPPED
}

enum DrawMode {
  WEIGHTED
  RANDOM
}

// ── Capacity planning ─────────────────────────────────────────────────────────

model CapacityEvent {
  id                 String              @id @default(cuid())
  name               String
  ownerId            String
  teamId             String?
  parentId           String?
  type               CapacityEventType   @default(SPRINT)
  status             CapacityEventStatus @default(PLANNING)
  startDate          DateTime
  endDate            DateTime
  workingDays        Int[]               @default([1, 2, 3, 4, 5])
  hoursPerDay        Float               @default(8)
  focusFactor        Float               @default(0.8)
  pointsPerPersonDay Float?
  committedPoints    Float?
  completedPoints    Float?
  notes              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  owner    User                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  team     Team?                 @relation(fields: [teamId], references: [id], onDelete: SetNull)
  parent   CapacityEvent?        @relation("EventChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children CapacityEvent[]       @relation("EventChildren")
  members  CapacityEventMember[]
}

model CapacityEventMember {
  id          String  @id @default(cuid())
  eventId     String
  name        String
  role        String?
  fte         Float   @default(1)
  focusFactor Float?
  order       Int     @default(0)

  event    CapacityEvent     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  absences CapacityAbsence[]
}

model CapacityAbsence {
  id            String   @id @default(cuid())
  eventMemberId String
  startDate     DateTime
  endDate       DateTime
  fraction      Float    @default(1)
  reason        String?
  createdAt     DateTime @default(now())

  member CapacityEventMember @relation(fields: [eventMemberId], references: [id], onDelete: Cascade)
}

enum CapacityEventType {
  PI_PLANNING
  SPRINT
  RELEASE
  CUSTOM
}

enum CapacityEventStatus {
  PLANNING
  ACTIVE
  DONE
}

// ── Board Voting ──────────────────────────────────────────────────────────────

model BoardVoteSession {
  id             String     @id @default(cuid())
  boardId        String
  status         VoteStatus @default(ACTIVE)
  votesPerPerson Int        @default(3)
  timerSeconds   Int?
  timerEndsAt    DateTime?
  voterIds       String[]
  createdAt      DateTime   @default(now())
  closedAt       DateTime?

  board Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  votes BoardVote[]
}

model BoardVote {
  id        String   @id @default(cuid())
  sessionId String
  cardId    String
  userId    String
  createdAt DateTime @default(now())

  session BoardVoteSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum VoteStatus {
  ACTIVE
  CLOSED
}

// ── Wheel / Random picker ─────────────────────────────────────────────────────

model WheelEvent {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  draws WheelDraw[]
}

model WheelDraw {
  id        String    @id @default(cuid())
  ownerId   String
  teamId    String?
  teamName  String?
  eventId   String?
  note      String?
  count     Int
  mode      DrawMode  @default(WEIGHTED)
  results   String[]
  excluded  String[]
  createdAt DateTime  @default(now())

  owner User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  team  Team?       @relation(fields: [teamId], references: [id], onDelete: SetNull)
  event WheelEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)
}

// ── MeetOps (gestion de réunions) ───────────────────────────────────────────────
// Hiérarchie : Événement → Réunion → Participant (liste de réunions à plat).
// Socle CRUD : envoi (.ics/SMTP/Graph), listes de diffusion, historique et
// templates arriveront dans les itérations suivantes (cf. docs/specs/meetops.md).

model MeetEvent {
  id          String          @id @default(cuid())
  ownerId     String
  name        String
  description String?
  type        MeetEventType   @default(CUSTOM)
  status      MeetEventStatus @default(DRAFT)
  startDate   DateTime?
  endDate     DateTime?
  color       String          @default("#475569")
  tags        String[]        @default([])
  templateId  String? // template d'origine (compteur « N événements créés depuis »)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  owner     User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  template  MeetTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  meetings  Meeting[]
  distLists MeetDistList[]
  history   MeetHistory[]
}

model Meeting {
  id          String        @id @default(cuid())
  eventId     String
  title       String
  label       String? // étiquette libre de classement (ex. Daily, Review…)
  order       Int           @default(0) // ordre manuel d'affichage (drag & drop)
  startAt     DateTime
  durationMin Int           @default(60)
  location    String?
  agenda      String?
  status      MeetingStatus @default(DRAFT)
  externalId  String? // ID de l'événement Outlook (Graph) une fois envoyé
  teamsUrl    String? // lien de réunion Teams (onlineMeeting.joinUrl)
  sendError   String? // dernier message d'erreur d'envoi (pour reprise)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  event        MeetEvent            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  participants MeetingParticipant[]
}

model MeetingParticipant {
  id        String      @id @default(cuid())
  meetingId String
  email     String
  name      String?
  role      String? // organisateur / requis / optionnel
  rsvp      MeetingRsvp @default(PENDING)

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

// Liste de diffusion réutilisable : un groupe de destinataires que l'on applique
// à une réunion (ses membres deviennent des MeetingParticipant). eventId null =
// liste globale de l'utilisateur ; sinon liste locale à un événement.
model MeetDistList {
  id        String           @id @default(cuid())
  ownerId   String
  eventId   String?
  name      String
  members   MeetDistMember[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  owner User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  event MeetEvent? @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model MeetDistMember {
  id     String  @id @default(cuid())
  listId String
  email  String
  name   String?
  role   String?

  list MeetDistList @relation(fields: [listId], references: [id], onDelete: Cascade)
}

// Journal d'activité au niveau événement (survit à la suppression d'une réunion).
model MeetHistory {
  id           String    @id @default(cuid())
  eventId      String
  meetingId    String? // null = action sur l'événement
  meetingTitle String? // libellé figé au moment de l'action
  userId       String?
  action       String // created | updated | deleted | sent | reordered | bulk
  field        String?
  oldValue     String?
  newValue     String?
  createdAt    DateTime  @default(now())

  event MeetEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
}

// ── Cahiers de tests ───────────────────────────────────────────────────────────

model TestBook {
  id          String         @id @default(cuid())
  ownerId     String
  title       String
  description String?
  version     String?
  status      TestBookStatus @default(DRAFT)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  owner    User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  sections TestSection[]
}

model TestSection {
  id        String     @id @default(cuid())
  bookId    String
  title     String
  order     Int        @default(0)
  createdAt DateTime   @default(now())

  book  TestBook   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  cases TestCase[]
}

model TestCase {
  id           String         @id @default(cuid())
  sectionId    String
  title        String
  precondition String?
  steps        String?
  expected     String?
  status       TestCaseStatus @default(TODO)
  order        Int            @default(0)
  createdAt    DateTime       @default(now())

  section TestSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
}

enum TestBookStatus {
  DRAFT
  REVIEW
  APPROVED
  ARCHIVED
}

enum TestCaseStatus {
  TODO
  PASS
  FAIL
  BLOCKED
  SKIP
}

// Modèle d'événement réutilisable. `lines` = réunions en décalages relatifs :
// [{ label, title, durationMin, dayOffset, time }] (pas de dates absolues).
model MeetTemplate {
  id          String        @id @default(cuid())
  ownerId     String
  name        String
  description String?
  type        MeetEventType @default(CUSTOM)
  color       String        @default("#475569")
  lines       Json
  isShared    Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  owner  User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  events MeetEvent[]
}

// Compte Microsoft connecté d'un utilisateur (OAuth2 délégué Microsoft Graph).
// Tokens chiffrés au repos. Un seul compte par utilisateur.
model MeetGraphAccount {
  id           String   @id @default(cuid())
  userId       String   @unique
  msUserId     String?
  msEmail      String?
  accessToken  String // chiffré (AES-256-GCM)
  refreshToken String // chiffré (AES-256-GCM)
  expiresAt    DateTime
  scope        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum MeetEventType {
  VERSION
  SPRINT
  COPIL
  COMOP
  RELEASE
  ONBOARDING
  CUSTOM
}

enum MeetEventStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

enum MeetingStatus {
  DRAFT
  SENT
  UPDATED
  CANCELLED
}

enum MeetingRsvp {
  PENDING
  ACCEPTED
  DECLINED
  TENTATIVE
}

// ── Quiz interactif ───────────────────────────────────────────────────────────

model Quiz {
  id         String        @id @default(cuid())
  title      String
  ownerId    String
  owner      User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  questions  QuizQuestion[]
  sessions   QuizSession[]
  isFavorite Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model QuizQuestion {
  id        String      @id @default(cuid())
  quizId    String
  quiz      Quiz        @relation(fields: [quizId], references: [id], onDelete: Cascade)
  text      String
  options   Json        // string[] de 2 à 4 options
  correct   Int         // index de la bonne réponse (0-based)
  timeLimit Int         @default(30)   // secondes
  points    Int         @default(1000)
  order     Int
  answers   QuizAnswer[]
}

model QuizSession {
  id              String           @id @default(cuid())
  quizId          String
  quiz            Quiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)
  ownerId         String
  owner           User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  code            String           @unique
  title           String?
  status          QuizStatus       @default(LOBBY)
  currentQuestion Int              @default(0)
  questionEndAt   DateTime?
  participants    QuizParticipant[]
  answers         QuizAnswer[]
  createdAt       DateTime         @default(now())
}

enum QuizStatus {
  LOBBY
  QUESTION
  REVEAL
  LEADERBOARD
  ENDED
}

model QuizParticipant {
  id        String      @id @default(cuid())
  sessionId String
  session   QuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name      String
  score     Int         @default(0)
  answers   QuizAnswer[]
  createdAt DateTime    @default(now())

  @@unique([sessionId, name])
}

model QuizAnswer {
  id            String          @id @default(cuid())
  sessionId     String
  session       QuizSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId    String
  question      QuizQuestion    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  participantId String
  participant   QuizParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  optionIndex   Int
  isCorrect     Boolean
  responseMs    Int
  pointsEarned  Int
  createdAt     DateTime        @default(now())

  @@unique([sessionId, questionId, participantId])
}

// ── Mini-jeux ────────────────────────────────────────────────────────────────

model GameScore {
  id        String   @id @default(cuid())
  userId    String
  game      String   // 'postit-rush' | 'trivia' | 'bingo'
  score     Int
  metadata  Json?    // ex: { combo, accuracy, correctAnswers }
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([game, score(sort: Desc)])
}
