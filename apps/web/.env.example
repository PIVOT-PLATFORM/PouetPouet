NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# Shows the "create without verification" test button on the register page.
# Must mirror the API's ALLOW_EMAIL_BYPASS. Set to false (or remove) in production.
NEXT_PUBLIC_ALLOW_EMAIL_BYPASS=true

# Sentry error tracking. Leave empty to disable (dev default).
# SENTRY_DSN = server-side errors, NEXT_PUBLIC_SENTRY_DSN = browser errors.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
